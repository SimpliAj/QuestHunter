# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID
DISCORD_APP_ID=your_discord_app_id_here

# User Token (for quest scraper - optional)
USER_TOKEN=your_discord_user_token_here

# Notification Channel ID (get this from your Discord server - right-click channel > Copy Channel ID)
NOTIFICATION_CHANNEL_ID=your_channel_id_here

# Webhook URL for quest scraper
WEBHOOK_URL=http://localhost:3001/webhook/quests

# Webhook Port
WEBHOOK_PORT=3001

# Scanning interval in milliseconds
# Default: 3600000 = 1 hour (60 minutes) for scraper
SCRAPER_INTERVAL=3600000

# Enable/disable the /spoofguide command
# Set to 'true' to enable, 'false' to disable
ENABLE_SPOOFGUIDE=true

# Bot Version
# Update this to match your release version
BOT_VERSION=1.0.1

# Feedback/Bug Report Webhook URL
# Used to receive bug reports and feature requests from users
FEEDBACK_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id_here
