# ============================================
# QuestFinder Bot Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# DISCORD BOT SETTINGS
# ============================================

# Discord Bot Token
# Get from: https://discord.com/developers/applications -> Your App -> Bot -> TOKEN
DISCORD_TOKEN=your_bot_token_here

# Discord Application ID
# Get from: https://discord.com/developers/applications -> Your App -> General Information
DISCORD_APP_ID=your_app_id_here

# ============================================
# QUEST SCRAPER SETTINGS
# ============================================

# User Token (for quest scraper)
# Get from: https://discord.com -> DevTools (F12) -> Application -> Local Storage -> token
# Optional if USE_ACCOUNTS_FILE=true
USER_TOKEN=your_user_token_here

# Use accounts.txt for scraping
# Set to 'true' to use multiple accounts from accounts.txt (recommended)
# Set to 'false' to only use USER_TOKEN from this .env file
USE_ACCOUNTS_FILE=false

# Scanning interval in milliseconds
# 900000 = 15 minutes (at :00, :15, :30, :45)
# 3600000 = 1 hour (60 minutes)
# Recommended: 900000 to avoid Discord rate limiting and account bans
SCRAPER_INTERVAL=900000

# ============================================
# NOTIFICATION SETTINGS
# ============================================

# Notification Channel ID
# Where the bot sends quest notifications
# Get this: Right-click channel in Discord -> Copy Channel ID
NOTIFICATION_CHANNEL_ID=your_channel_id_here

# Webhook URL for quest scraper
# Local webhook endpoint for the scraper to send data to the bot
WEBHOOK_URL=http://localhost:3001/webhook/quests

# Webhook Port
# Port for the local webhook server
WEBHOOK_PORT=3001

# Share Code Channel ID
# Where shared game codes are posted
# Get this: Right-click channel in Discord -> Copy Channel ID
SHARE_CHANNEL_ID=your_channel_id_here

# Feedback/Bug Report Webhook URL
# Where user feedback and bug reports are sent
# Create a Discord webhook in your private server
FEEDBACK_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Error/Alert Webhook URL
# Where critical errors and alerts are sent (token issues, scraper stuck, etc.)
# Create a Discord webhook in your private server
ERROR_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ============================================
# BOT SETTINGS
# ============================================

# Enable/disable the /spoofguide command
# Set to 'true' to enable, 'false' to disable
ENABLE_SPOOFGUIDE=false

# Bot Version
# Update this to match your release version
BOT_VERSION=1.0.1

# ============================================
# SECURITY NOTE
# ============================================
# NEVER commit the actual .env file to Git!
# Always use .env.example as a template
# Keep your tokens private and secure!
