{
  "name": "questfinder-bot",
  "version": "1.0.0",
  "description": "Discord bot that scans for new quests and sends notifications",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "scrape": "node questScraper.js",
    "all": "concurrently \"npm run scrape\" \"npm start\""
  },
  "dependencies": {
    "discord.js": "^14.14.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "puppeteer": "^24.0.0",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
